PORT=3000
NODE_ENV=production
LOG_LEVEL=info

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=1800

CORS_ORIGIN=*

SHOPIFY_SHOP_DOMAIN=alasil.ae
SHOPIFY_STOREFRONT_TOKEN=your-token-here
SHOPIFY_API_VERSION=2024-01
SHOPIFY_CACHE_TTL_SECONDS=300
SHOPIFY_CATALOG_MAX=5000
FEATURE_LIVE_SEARCH=true

TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_PUBLIC_URL=
TELEGRAM_ADMIN_USERS=7866231058
# Merge rapid-fire messages sent within this many ms into one agent turn.
# Customers often split a thought across 2-3 messages ("hello" / "i need X" /
# "do you have?") — without debouncing the bot replies to each fragment.
TELEGRAM_DEBOUNCE_MS=2500
# ^^ comma-separated Telegram user IDs who can train the bot conversationally ("good"/"bad")

# LLM tool-calling agent (new smarter search pipeline)
# When true, Telegram requests route through src/modules/agent.js (LLM decides which tool to call).
# When false, uses the legacy regex + response.js pipeline.
USE_AGENT=false
AGENT_MAX_ITERATIONS=5
# Leave AGENT_MODEL empty to use OPENAI_MODEL; override for agent-only if needed (e.g. gpt-4o)
AGENT_MODEL=

# Max concurrent OpenAI calls across the process (gate everyone waits in).
# Tune higher if you are on Tier 2+ with 2M+ TPM; default 10 keeps us safely
# under the 500 RPM / 200k TPM Free/Tier-1 limits.
AGENT_MAX_CONCURRENT=10
# Retries for 429 / 5xx / network errors before falling back to escalation reply.
AGENT_MAX_RETRIES=3

# Monitoring dashboard (/dashboard/:secret). Leave blank for public /dashboard.
DASHBOARD_SECRET=
